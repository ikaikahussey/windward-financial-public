---
import NewsletterForm from './islands/NewsletterForm';
---

<footer class="bg-primary-dark text-white">
  <div class="container-wide mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10">
      <div>
        <div class="mb-4">
          <img src="/logo.png" alt="Windward Financial" class="h-12 w-auto brightness-0 invert" />
        </div>
        <p class="text-primary-light/80 text-sm italic leading-relaxed">
          Honesty, communication, trust, and expertise
        </p>
      </div>

      <div>
        <h4 class="font-heading text-lg mb-4">Quick Links</h4>
        <ul class="space-y-2 text-sm">
          <li><a href="/about" class="text-primary-light/80 hover:text-white transition-colors">About Us</a></li>
          <li><a href="/expertise" class="text-primary-light/80 hover:text-white transition-colors">Expertise</a></li>
          <li><a href="/quality-commitment" class="text-primary-light/80 hover:text-white transition-colors">Quality Commitment</a></li>
          <li><a href="/calculator" class="text-primary-light/80 hover:text-white transition-colors">Retirement Calculator</a></li>
          <li><a href="/resources" class="text-primary-light/80 hover:text-white transition-colors">Resources</a></li>
          <li><a href="/schedule-an-appointment" class="text-primary-light/80 hover:text-white transition-colors">Schedule Appointment</a></li>
        </ul>
      </div>

      <div>
        <h4 class="font-heading text-lg mb-4">Contact Us</h4>
        <ul class="space-y-3 text-sm text-primary-light/80">
          <li class="flex items-start gap-2">
            <svg class="w-5 h-5 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
            </svg>
            <a href="tel:+18888941884" class="hover:text-white transition-colors">(888) 894-1884</a>
          </li>
          <li class="flex items-start gap-2">
            <svg class="w-5 h-5 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
            </svg>
            <a href="mailto:info@windward.financial" class="hover:text-white transition-colors">info@windward.financial</a>
          </li>
        </ul>
      </div>

      <div>
        <h4 class="font-heading text-lg mb-4">Stay Informed</h4>
        <p class="text-sm text-primary-light/80 mb-3">
          Get retirement planning tips and updates delivered to your inbox.
        </p>
        <NewsletterForm client:idle variant="footer" />
      </div>
    </div>

    <div class="border-t border-primary/30 mt-12 pt-8 text-center text-sm text-primary-light/60">
      <p>&copy; 2026 Windward Financial | CA License # 2087268</p>
    </div>
  </div>
</footer>
