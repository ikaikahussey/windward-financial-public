---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const teamEntries = (await getCollection('team', ({ data }) => data.published))
  .sort((a, b) => a.data.displayOrder - b.data.displayOrder);

const team = await Promise.all(teamEntries.map(async (entry) => {
  const { Content } = await entry.render();
  return { id: entry.id, data: entry.data, Content };
}));

const initials = (name: string) => name.split(' ').map((n) => n[0]).join('');
---

<BaseLayout
  title="About Us | Windward Financial"
  description="Learn about our history, our team, and our commitment to serving Hawaii's public employees."
>
  <section class="bg-primary-dark py-16 md:py-20">
    <div class="container-wide mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="font-heading text-4xl md:text-5xl text-white mb-4">About Windward Financial</h1>
      <p class="text-primary-light/80 text-xl max-w-2xl">
        A family legacy of service to public employees — rooted in Hawaiʻi, growing across the West.
      </p>
    </div>
  </section>

  <section class="section-padding bg-white">
    <div class="container-narrow mx-auto">
      <h2 class="font-heading text-3xl md:text-4xl text-primary-dark mb-8">Our History</h2>
      <div class="space-y-6 text-gray-700 leading-relaxed text-lg">
        <p>
          <strong>Herbert Hussey</strong> began his career in the retirement planning industry as the 403(b) specialist serving Hawaii's Department of Education teachers in 1990. Assigned to the island of Kauaʻi, Herb spent five years guiding several hundred educators through their retirement planning. Recognizing the growing need for trusted guidance on Medicare and retirement, he expanded his reach statewide. After fifteen years in the industry, Herb felt a deep personal commitment to continue serving his community.
        </p>
        <p>
          In <strong>2005</strong>, he founded Windward Financial LLC — rooted in Hawaiʻi, built on relationships, and dedicated to the educators and public servants who give so much to their communities. The company was built on four pillars: <em>honesty, communication, trust, and expertise</em>. What began as a Hawaii-focused practice has grown naturally: today Windward Financial serves state and county employees, educators, and public servants across Hawaii, California, Oregon, and Washington, with a team of well-qualified agents that includes Herb's own sons.
        </p>
        <p>
          Before COVID, our agents visited schools and worksites in person across every state we serve. Since the pandemic, Windward Financial has embraced virtual education — hosting regular Zoom workshops to keep public employees up to date on their state retirement systems, Medicare integration, and benefit options, no matter where they live or work.
        </p>
      </div>
    </div>
  </section>

  <section class="section-padding bg-sand">
    <div class="container-narrow mx-auto">
      <h2 class="font-heading text-3xl md:text-4xl text-primary-dark mb-12 text-center">Our Journey</h2>
      <div class="space-y-8">
        {[
          { year: '1990', text: "Herb Hussey begins his career serving Hawaii's public employees" },
          { year: '2005', text: 'Windward Financial is founded with a mission of honest, personalized financial guidance' },
          { year: '2020', text: 'Successfully pivots to virtual consultations during COVID-19, expanding statewide reach' },
          { year: 'Today', text: 'Serving public employees across Hawaii, California, Oregon, and Washington with trusted financial guidance, including Section 125 MEC plans' },
        ].map(({ year, text }) => (
          <div class="flex gap-6 items-start">
            <div class="shrink-0 w-20 text-right">
              <span class="font-heading text-xl text-primary font-bold">{year}</span>
            </div>
            <div class="w-px bg-primary/30 shrink-0 self-stretch"></div>
            <p class="text-gray-700 text-lg pt-0.5">{text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section-padding bg-white">
    <div class="container-wide mx-auto">
      <h2 class="font-heading text-3xl md:text-4xl text-primary-dark mb-4 text-center">Our Team</h2>
      <p class="text-gray-600 text-lg text-center mb-12 max-w-2xl mx-auto">
        Meet the dedicated professionals who make Windward Financial the trusted partner for public employees across the states we serve.
      </p>

      {team.length > 0 ? (
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8">
          {team.map((member) => (
            <div class="card text-center hover:shadow-xl transition-shadow">
              <div class="w-24 h-24 bg-primary-light rounded-full flex items-center justify-center mx-auto mb-5">
                {member.data.photo ? (
                  <img src={member.data.photo} alt={member.data.name} class="w-24 h-24 rounded-full object-cover" />
                ) : (
                  <span class="text-primary-dark font-heading text-3xl">
                    {initials(member.data.name)}
                  </span>
                )}
              </div>
              <h3 class="font-heading text-xl text-primary-dark mb-1">{member.data.name}</h3>
              <p class="text-primary font-medium mb-4">{member.data.title}</p>
              <div class="text-gray-600 text-sm mb-4 prose prose-sm max-w-none">
                <member.Content />
              </div>
              <div class="space-y-1 text-sm">
                {member.data.email && (
                  <a href={`mailto:${member.data.email}`} class="block text-ocean hover:underline">
                    {member.data.email}
                  </a>
                )}
                {member.data.phone && (
                  <a href={`tel:${member.data.phone}`} class="block text-ocean hover:underline">
                    {member.data.phone}
                  </a>
                )}
              </div>
            </div>
          ))}
        </div>
      ) : (
        <div class="text-center py-12">
          <p class="text-gray-500 mb-4">Team information is currently being updated.</p>
          <p class="text-gray-600">
            Please call us at <a href="tel:+18888941884" class="text-primary font-semibold hover:underline">(888) 894-1884</a> to speak with a team member.
          </p>
        </div>
      )}
    </div>
  </section>
</BaseLayout>
