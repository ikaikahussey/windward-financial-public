---
import BaseLayout from '../layouts/BaseLayout.astro';

interface Product {
  name: string;
  description: string;
}

interface Category {
  title: string;
  iconPath: string;
  description: string;
  products: Product[];
}

const categories: Category[] = [
  {
    title: 'Insurance',
    iconPath: 'M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z',
    description: 'Protect your family with life insurance products that include living benefits through Accelerated Benefit Riders.',
    products: [
      {
        name: 'Term Life Insurance with ABR',
        description: 'Affordable, flexible coverage for a specific period. Includes an Accelerated Benefit Rider that provides access to a portion of the death benefit if diagnosed with a qualifying chronic, critical, or terminal illness.',
      },
      {
        name: 'Guaranteed Universal Life with ABR',
        description: 'Permanent life insurance with guaranteed premiums and death benefit. The Accelerated Benefit Rider provides living benefits for qualifying illnesses, giving you peace of mind for the unexpected.',
      },
      {
        name: 'Indexed Universal Life with ABR',
        description: 'Permanent coverage with cash value growth potential linked to market index performance, plus downside protection. Includes Accelerated Benefit Rider for qualifying illness access to death benefit funds.',
      },
    ],
  },
  {
    title: 'Annuities',
    iconPath: 'M2.25 18L9 11.25l4.306 4.307a11.95 11.95 0 015.814-5.519l2.74-1.22m0 0l-5.94-2.28m5.94 2.28l-2.28 5.941',
    description: 'Build guaranteed retirement income with annuity products that offer protected growth and lifetime income options.',
    products: [
      {
        name: 'Fixed Indexed Annuity with GLIR',
        description: 'Grow your retirement savings with returns linked to market index performance while protecting your principal from market downturns. The Guaranteed Lifetime Income Rider ensures you never outlive your income.',
      },
    ],
  },
  {
    title: '403(b) Savings Plan',
    iconPath: 'M12 21v-8.25M15.75 21v-8.25M8.25 21v-8.25M3 9l9-6 9 6m-1.5 12V10.332A48.36 48.36 0 0012 9.75c-2.551 0-5.056.2-7.5.582V21M3 21h18M12 6.75h.008v.008H12V6.75z',
    description: 'Tax-advantaged retirement savings plans designed specifically for public school employees and non-profit workers.',
    products: [
      {
        name: 'Flexible Premium Deferred Annuity (FPDA)',
        description: 'A flexible 403(b) option that allows you to adjust your contribution amounts as your financial situation changes. Ideal for public employees who want the freedom to increase or decrease savings over time while still enjoying tax-deferred growth.',
      },
    ],
  },
];
---

<BaseLayout
  title="Our Expertise | Windward Financial"
  description="Insurance, annuities, and 403(b) savings plans designed for Hawaii public employees."
>
  <section class="bg-primary-dark py-16 md:py-20">
    <div class="container-wide mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="font-heading text-4xl md:text-5xl text-white mb-4">Our Expertise</h1>
      <p class="text-primary-light/80 text-xl max-w-2xl">
        Comprehensive financial products tailored for Hawaii's public employees.
      </p>
    </div>
  </section>

  {categories.map((category, idx) => (
    <section class={`section-padding ${idx % 2 === 0 ? 'bg-white' : 'bg-sand'}`}>
      <div class="container-wide mx-auto">
        <div class="flex items-center gap-4 mb-4">
          <div class="w-14 h-14 bg-primary-light rounded-xl flex items-center justify-center shrink-0">
            <svg class="w-8 h-8 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={category.iconPath} />
            </svg>
          </div>
          <h2 class="font-heading text-3xl md:text-4xl text-primary-dark">{category.title}</h2>
        </div>
        <p class="text-gray-600 text-lg mb-10 max-w-3xl">{category.description}</p>

        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
          {category.products.map((product) => (
            <div class="card flex flex-col hover:shadow-xl transition-shadow">
              <h3 class="font-heading text-xl text-primary-dark mb-3">{product.name}</h3>
              <p class="text-gray-600 mb-6 flex-1">{product.description}</p>
              <a href="/schedule-an-appointment" class="btn-primary text-center text-sm">
                Schedule a Consultation
              </a>
            </div>
          ))}
        </div>
      </div>
    </section>
  ))}

  <section class="section-padding bg-primary-dark">
    <div class="container-narrow mx-auto text-center">
      <h2 class="font-heading text-3xl md:text-4xl text-white mb-6">Not Sure Which Product Is Right for You?</h2>
      <p class="text-primary-light/80 text-lg mb-8 max-w-2xl mx-auto">
        Every situation is unique. Schedule a free consultation and we'll help you find the right combination of products to meet your goals.
      </p>
      <a href="/schedule-an-appointment" class="btn-sand text-lg">
        Schedule a Free Consultation
      </a>
    </div>
  </section>
</BaseLayout>
