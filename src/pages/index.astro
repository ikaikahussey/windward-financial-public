---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import TestimonialsSlider, { type TestimonialItem } from '../components/islands/TestimonialsSlider';
import NewsletterForm from '../components/islands/NewsletterForm';

const testimonialEntries = (await getCollection('testimonials', ({ data }) => data.published))
  .sort((a, b) => a.data.displayOrder - b.data.displayOrder);

const testimonialItems: TestimonialItem[] = testimonialEntries.map((entry) => ({
  id: entry.id,
  authorName: entry.data.authorName,
  authorDescription: entry.data.authorDescription,
  body: entry.body.trim(),
}));

const NLG_LOGIN_URL = import.meta.env.PUBLIC_NLG_LOGIN_URL || 'https://www.nationallife.com/login';
---

<BaseLayout
  title="Windward Financial | Retirement Planning for Hawaii Public Employees"
  description="Family-owned financial services company serving Hawaii's public employees since 1990. Insurance, annuities, and 403(b) retirement plans."
>
  <section class="relative bg-primary-dark overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-primary-dark via-primary to-ocean opacity-90"></div>
    <div class="absolute inset-0 opacity-10">
      <div class="absolute top-20 right-20 w-96 h-96 bg-primary-light rounded-full blur-3xl"></div>
      <div class="absolute bottom-10 left-10 w-64 h-64 bg-ocean-light rounded-full blur-3xl"></div>
    </div>
    <div class="relative container-wide mx-auto px-4 sm:px-6 lg:px-8 py-24 md:py-36">
      <div class="max-w-3xl">
        <h1 class="font-heading text-4xl md:text-5xl lg:text-6xl text-white mb-6 leading-tight">
          Windward Financial
        </h1>
        <p class="text-xl md:text-2xl text-primary-light/90 mb-4 font-light leading-relaxed">
          A family-owned financial services company serving educators, public school employees, and state and county workers across Hawaii, California, Oregon, and Washington since 1990.
        </p>
        <p class="text-lg text-primary-light/70 mb-10">
          Retirement planning, insurance, annuities, and 403(b) plans tailored to your needs.
        </p>
        <div class="flex flex-wrap gap-4">
          <a href="/schedule-an-appointment" class="btn-sand text-lg">
            Schedule a Consultation
          </a>
          <a
            href={NLG_LOGIN_URL}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-block border-2 border-primary-light/40 text-primary-light font-semibold px-6 py-3 rounded-lg hover:bg-primary-light/10 transition-colors text-lg"
          >
            Check My Account
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="section-padding bg-sand">
    <div class="container-wide mx-auto">
      <div class="text-center mb-14">
        <h2 class="font-heading text-3xl md:text-4xl text-primary-dark mb-4">How We Help You</h2>
        <p class="text-gray-600 max-w-2xl mx-auto text-lg">
          We specialize in financial solutions designed for public employees — from the ERS and TRS to PERS and STRS — giving you personalized guidance wherever you teach or serve.
        </p>
      </div>
      <div class="grid md:grid-cols-2 gap-8 max-w-4xl mx-auto">
        <a href="/expertise" class="card group hover:shadow-xl transition-shadow">
          <div class="w-14 h-14 bg-primary-light rounded-xl flex items-center justify-center mb-5">
            <svg class="w-7 h-7 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />
            </svg>
          </div>
          <h3 class="font-heading text-2xl text-primary-dark mb-3">Our Expertise</h3>
          <p class="text-gray-600 mb-4">
            Insurance, annuities, and 403(b) savings plans designed specifically for public employees. We help you protect your family and build your retirement.
          </p>
          <span class="text-primary font-semibold group-hover:underline">Learn More &rarr;</span>
        </a>

        <a href="/quality-commitment" class="card group hover:shadow-xl transition-shadow">
          <div class="w-14 h-14 bg-primary-light rounded-xl flex items-center justify-center mb-5">
            <svg class="w-7 h-7 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z" />
            </svg>
          </div>
          <h3 class="font-heading text-2xl text-primary-dark mb-3">Quality Commitment</h3>
          <p class="text-gray-600 mb-4">
            Over 30 years of dedicated service built on honesty, communication, trust, and expertise. Your financial future is our priority.
          </p>
          <span class="text-primary font-semibold group-hover:underline">Learn More &rarr;</span>
        </a>
      </div>
    </div>
  </section>

  <section class="section-padding bg-white">
    <div class="container-narrow mx-auto text-center">
      <h2 class="font-heading text-3xl md:text-4xl text-primary-dark mb-6">Get in Touch</h2>
      <p class="text-lg text-gray-600 mb-8 max-w-2xl mx-auto">
        We offer free, no-obligation consultations to help you understand your options. Whether you're just starting your career or planning for retirement, we're here to help.
      </p>
      <div class="flex flex-wrap justify-center gap-8 mb-10">
        <a href="tel:+18888941884" class="flex items-center gap-3 text-primary-dark hover:text-primary transition-colors">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
          </svg>
          <span class="text-lg font-semibold">(888) 894-1884</span>
        </a>
        <a href="mailto:info@windward.financial" class="flex items-center gap-3 text-primary-dark hover:text-primary transition-colors">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
          </svg>
          <span class="text-lg font-semibold">info@windward.financial</span>
        </a>
      </div>
      <a href="/schedule-an-appointment" class="btn-primary text-lg">
        Schedule a Free Consultation
      </a>
    </div>
  </section>

  {testimonialItems.length > 0 && (
    <section class="section-padding bg-primary-dark">
      <div class="container-narrow mx-auto text-center">
        <h2 class="font-heading text-3xl md:text-4xl text-white mb-12">What Our Clients Say</h2>
        <TestimonialsSlider client:load items={testimonialItems} />
      </div>
    </section>
  )}

  <section class="section-padding bg-sand">
    <div class="container-narrow mx-auto text-center">
      <h2 class="font-heading text-3xl md:text-4xl text-primary-dark mb-4">Stay Informed</h2>
      <p class="text-gray-600 mb-8 text-lg">
        Subscribe to our newsletter for retirement planning tips, benefit updates, and financial insights for public employees across the states we serve.
      </p>
      <NewsletterForm client:idle variant="page" />
    </div>
  </section>
</BaseLayout>
