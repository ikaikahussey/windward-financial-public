---
import BaseLayout from '../layouts/BaseLayout.astro';

const goals = [
  {
    title: 'Personalized Service',
    description: 'Every client receives a customized financial plan tailored to their unique situation, career stage, and retirement goals. We never offer one-size-fits-all solutions.',
  },
  {
    title: 'Education First',
    description: 'We believe informed clients make better decisions. We take the time to explain every product, benefit, and option so you can choose with confidence.',
  },
  {
    title: 'Long-Term Relationships',
    description: 'We are not transaction-focused. We build lasting relationships and provide ongoing support through every stage of your career and into retirement.',
  },
  {
    title: 'Accessibility',
    description: 'Financial guidance should be available to everyone. We offer free consultations, flexible scheduling, virtual meetings, and on-site presentations at schools and government offices.',
  },
  {
    title: 'Community Impact',
    description: 'By helping public employees secure their financial futures, we strengthen the communities they serve. When our teachers, first responders, and government workers thrive, Hawaii thrives.',
  },
];

const affiliations = [
  'National Life Group — Independent Agent',
  'NTSA — Certified Retirement Education Specialist',
];
---

<BaseLayout
  title="Quality Commitment | Windward Financial"
  description="Our mission, competitive advantages, and commitment to excellence in financial services."
>
  <section class="bg-primary-dark py-16 md:py-20">
    <div class="container-wide mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="font-heading text-4xl md:text-5xl text-white mb-4">Quality Commitment</h1>
      <p class="text-primary-light/80 text-xl max-w-2xl">
        Our promise of excellence in every interaction.
      </p>
    </div>
  </section>

  <section class="section-padding bg-sand">
    <div class="container-narrow mx-auto text-center">
      <h2 class="font-heading text-3xl md:text-4xl text-primary-dark mb-8">Our Mission</h2>
      <div class="bg-white rounded-2xl shadow-lg p-8 md:p-12 border-l-4 border-primary">
        <p class="text-xl md:text-2xl text-gray-700 italic leading-relaxed font-light">
          "To provide Hawaii's public employees with honest, personalized financial guidance that empowers them to protect their families, build their retirement, and achieve lasting financial security."
        </p>
      </div>
    </div>
  </section>

  <section class="section-padding bg-white">
    <div class="container-wide mx-auto">
      <h2 class="font-heading text-3xl md:text-4xl text-primary-dark mb-10 text-center">Our Competitive Advantage</h2>
      <div class="grid md:grid-cols-2 gap-10 max-w-5xl mx-auto">
        <div class="card hover:shadow-xl transition-shadow">
          <div class="w-14 h-14 bg-primary-light rounded-xl flex items-center justify-center mb-5">
            <svg class="w-7 h-7 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="font-heading text-2xl text-primary-dark mb-3">30+ Years of Experience</h3>
          <p class="text-gray-600 leading-relaxed">
            Since 1990, we have been exclusively dedicated to serving Hawaii's public employees. Our deep understanding of ERS pension plans, EUTF benefits, 403(b) options, and the unique financial challenges facing teachers, state workers, and county employees sets us apart from generalist financial advisors.
          </p>
        </div>

        <div class="card hover:shadow-xl transition-shadow">
          <div class="w-14 h-14 bg-primary-light rounded-xl flex items-center justify-center mb-5">
            <svg class="w-7 h-7 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z" />
            </svg>
          </div>
          <h3 class="font-heading text-2xl text-primary-dark mb-3">Benchmark Insurance Group</h3>
          <p class="text-gray-600 leading-relaxed">
            Our relationship with The Benchmark Insurance Group gives us access to a wide range of insurance carriers and products, ensuring we can find the best fit for each client. This partnership allows us to offer competitive rates and comprehensive coverage options that standalone agencies simply cannot match.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="section-padding bg-primary-dark">
    <div class="container-wide mx-auto">
      <h2 class="font-heading text-3xl md:text-4xl text-white mb-12 text-center">Our 5 Goals</h2>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8 max-w-6xl mx-auto">
        {goals.map((goal, i) => (
          <div class={`bg-primary/40 backdrop-blur rounded-xl p-6 md:p-8 border border-primary/30 ${i === 4 ? 'sm:col-span-2 lg:col-span-1' : ''}`}>
            <div class="w-10 h-10 bg-primary-light rounded-full flex items-center justify-center mb-4">
              <span class="text-primary-dark font-bold text-lg">{i + 1}</span>
            </div>
            <h3 class="font-heading text-xl text-white mb-3">{goal.title}</h3>
            <p class="text-primary-light/80 leading-relaxed">{goal.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section-padding bg-sand">
    <div class="container-narrow mx-auto text-center">
      <h2 class="font-heading text-3xl md:text-4xl text-primary-dark mb-8">Our Affiliations</h2>
      <div class="grid sm:grid-cols-2 md:grid-cols-3 gap-6">
        {affiliations.map((org) => (
          <div class="bg-white rounded-lg shadow-sm p-6 flex items-center justify-center text-center">
            <span class="text-gray-700 font-medium">{org}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section-padding bg-white">
    <div class="container-narrow mx-auto text-center">
      <h2 class="font-heading text-3xl md:text-4xl text-primary-dark mb-6">Experience the Windward Difference</h2>
      <p class="text-gray-600 text-lg mb-8">
        Schedule a free consultation and discover why Hawaii's public employees trust us with their financial futures.
      </p>
      <a href="/schedule-an-appointment" class="btn-primary text-lg">
        Schedule a Consultation
      </a>
    </div>
  </section>
</BaseLayout>
